graph TB
    subgraph Explorer["Interactive Explorer — GitHub Pages"]
        PARETO[Pareto Frontier]
        SHAP_VIZ[SHAP Feature Importance]
        TIMELINE[Competitive Timeline]
        PAPERS[Paper Browser]
    end

    subgraph LNPOptimizer["src/lnp_optimizer — ML Pipeline"]
        FM[Feature Matrix Builder]
        FE[Feature Engineering]
        ML[ML Models — LightGBM / XGBoost]
        SH[SHAP Interpretability]
        GP[GP Classifier — Gap Scoring]
        PC[Pareto Analysis]
        TW[Therapeutic Window — 4PL Fits]
        TR[Transfer Learning]
        IL[Lian Integration]
    end

    subgraph Shared["src/shared — Infrastructure"]
        CFG[Config — .env + Pydantic Settings]
        SCH[Pydantic Models]
    end

    subgraph Data["data/ — Curated Datasets"]
        HSC[(hsc_curated.parquet — 156 records)]
        FEAT[(hsc_features.parquet — 135 × 37)]
        KIM[(kim_screen — 128 decoded LNPs)]
        MOD[(models/ — JSON + parquet outputs)]
        AUD[audit/ — 8 verification scripts]
    end

    subgraph Annotations["annotations/ — 21 Papers"]
        ANN[Ground truth JSONs]
    end

    Explorer -->|reads| MOD
    FM -->|builds from| HSC
    FM -->|outputs| FEAT
    FE --> FM
    ML -->|trains on| FEAT
    SH --> ML
    GP --> ML
    PC -->|reads| MOD
    TW -->|reads| ANN
    IL -->|adds Lian rows| FEAT
    TR -->|negative result| ML

    LNPOptimizer --> Shared
    ANN -->|curated data| FM
    KIM -->|screen data| FM
    ML -->|saves results| MOD
    GP -->|saves scores| MOD
    PC -->|saves frontiers| MOD
    TW -->|saves fits| MOD
