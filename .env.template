# LNP Research Platform — Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.template .env

# Anthropic Claude API key (required for LLM extraction)
ANTHROPIC_API_KEY=your-anthropic-key-here

# NCBI/PubMed API key (optional but recommended — increases rate limits)
NCBI_API_KEY=your-ncbi-key-here

# Email for NCBI API (required by NCBI usage policy)
NCBI_EMAIL=your-email@example.com
